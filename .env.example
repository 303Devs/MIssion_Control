# Mission Control local configuration
# Copy to .env.local and fill with local values. Do not commit real secrets.

# Canvas calendar feed used by /api/canvas.
CANVAS_ICAL_URL=

# Weather location used by /api/weather.
WEATHER_LAT=
WEATHER_LON=

# Optional path overrides for local agent/vault data.
MISSION_CONTROL_AGENTS_ROOT=
MISSION_CONTROL_OPENCLAW_ROOT=
MISSION_CONTROL_HERMES_ROOT=
MISSION_CONTROL_VAULT_ROOT=

# OpenClaw Gateway integration (Phase 5).
# Base URL for the OpenClaw Gateway API (e.g. http://localhost:4000).
OPENCLAW_GATEWAY_URL=
# Bearer token for Gateway API authentication.
OPENCLAW_GATEWAY_TOKEN=

# API auth for /api/* routes.
# If set, all API requests must include: Authorization: Bearer <value>
# If unset, API is restricted to localhost only (no token required).
MISSION_CONTROL_SECRET=
